<view class="container">
  <!-- 案例选择页面 -->
  <block wx:if="{{!patient}}">
    <view class="mode-tag mode-exam">语音考核</view>
    <view class="patient-select">
      <view class="card patient-card" wx:for="{{patients}}" wx:key="id"
        bindtap="selectPatient" data-id="{{item.id}}">
        <view style="flex:1">
          <text class="patient-name">{{item.name}}</text>
          <view class="patient-info" wx:if="{{item._subtitle}}">{{item._subtitle}}</view>
          <view class="patient-info" wx:if="{{item.medication}}">用药：{{item.medication}}</view>
        </view>
        <text class="patient-tag">选择</text>
      </view>
    </view>
  </block>

  <!-- 考核页面 -->
  <block wx:else>
    <!-- 资料卡片：通用 card_lines（如考核说明）优先；否则回退到患者医疗资料 -->
    <view class="patient-card">
      <block wx:if="{{patient.card_lines.length}}">
        <view class="card-title">{{patient.card_title || '说明'}}</view>
        <view class="info-row" wx:for="{{patient.card_lines}}" wx:key="label">
          <text class="label">{{item.label}}：</text>
          <text>{{item.value}}</text>
        </view>
      </block>
      <block wx:else>
        <view class="card-title">患者资料</view>
        <view class="info-row">
          <text class="label">姓名：</text>
          <text>{{patient.name}} {{patient.age}}岁 {{patient.gender}}</text>
        </view>
        <view class="info-row" wx:if="{{patient.diagnosis}}">
          <text class="label">诊断：</text>
          <text>{{patient.diagnosis}}</text>
        </view>
        <view class="info-row" wx:if="{{patient.medication}}">
          <text class="label">用药：</text>
          <text>{{patient.medication}}</text>
        </view>
        <view class="info-row" wx:if="{{patient.recommended_cgm_count}}">
          <text class="label">推荐台数：</text>
          <text style="color:#ff4444;font-weight:bold;">{{patient.recommended_cgm_count}}台CGM</text>
        </view>
        <view class="info-row" wx:if="{{patient.conversion_keys}}">
          <text class="label">转化要点：</text>
          <text>{{patient.conversion_keys.join('、')}}</text>
        </view>
      </block>
    </view>

    <!-- 对话状态（聆听时可点击提前结束） -->
    <view class="status-bar" bindtap="onStatusTap">
      <view class="status {{status}}">
        <text wx:if="{{status === 'listening'}}">🎤 正在聆听...（点击结束）</text>
        <text wx:elif="{{status === 'processing'}}">⏳ 处理中...</text>
        <text wx:elif="{{status === 'speaking'}}">🔊 AI回复中...</text>
        <text wx:else="{{status === 'idle'}}">💬 等待对话</text>
      </view>
    </view>

    <!-- 对话记录 -->
    <scroll-view class="messages" scroll-y scroll-into-view="msg-{{messages.length - 1}}">
      <view wx:for="{{messages}}" wx:key="index" id="msg-{{index}}" class="message {{item.role}}">
        <text class="role-tag">{{item.role === 'nurse' ? '我' : roleLabel}}</text>
        <text class="content">{{item.content}}</text>
      </view>
    </scroll-view>

    <!-- 控制按钮 -->
    <view class="controls">
      <button wx:if="{{!started}}" class="btn-start" bindtap="startExam">开始考核</button>
      <button wx:else class="btn-end" bindtap="endExam">结束考核</button>
    </view>
  </block>
</view>