<view class="container">
  <view class="logo-area">
    <text class="title">{{ui.homeTitle}}</text>
    <text class="subtitle">{{ui.homeSubtitle}}</text>
  </view>

  <block wx:if="{{!loggedIn && !showLogin}}">
    <view class="intro">
      <text class="intro-text">{{ui.introLine}}</text>
    </view>
    <view class="menu">
      <view class="card menu-item" bindtap="goFlashcard">
        <text class="menu-icon">📖</text>
        <text class="menu-title">{{ui.menuFlashcardTitle}}</text>
        <text class="menu-desc">{{ui.menuFlashcardDesc}}</text>
      </view>
      <view class="card menu-item" bindtap="goExam">
        <text class="menu-icon">💬</text>
        <text class="menu-title">{{ui.menuExamTitle}}</text>
        <text class="menu-desc">{{ui.menuExamDesc}}</text>
      </view>
      <view class="card menu-item" bindtap="goVoiceExam">
        <text class="menu-icon">🎤</text>
        <text class="menu-title">{{ui.menuVoiceTitle}}</text>
        <text class="menu-desc">{{ui.menuVoiceDesc}}</text>
      </view>
    </view>
    <view class="login-tip" bindtap="showLoginForm">登录后可查看考核记录</view>
  </block>

  <block wx:if="{{!loggedIn && showLogin}}">
    <view class="card">
      <input class="input" placeholder="请输入姓名" bindinput="onNameInput" value="{{name}}" />
      <input class="input" placeholder="请输入手机号" type="number" bindinput="onPhoneInput" value="{{phone}}" />
      <view class="agreement-row">
        <checkbox checked="{{agreed}}" color="#4A90D9" bindtap="toggleAgreed" />
        <text class="agreement-text" bindtap="toggleAgreed">请阅读并同意</text>
        <text class="agreement-link" catchtap="showAgreement">《用户协议》</text>
        <text class="agreement-text" bindtap="toggleAgreed">和</text>
        <text class="agreement-link" catchtap="showPrivacy">《隐私声明》</text>
      </view>
      <view class="btn-primary {{agreed ? '' : 'btn-disabled'}}" bindtap="login">登录</view>
      <view class="cancel-login" bindtap="cancelLogin">暂不登录</view>
    </view>
  </block>

  <block wx:if="{{loggedIn}}">
    <view class="welcome">你好，{{userInfo.name}}</view>
    <view class="subunit-bar" bindtap="goPickSubUnit">
      <text wx:if="{{hasSubUnit}}" class="subunit-text">当前场景已选择 · 点击更换</text>
      <text wx:else class="subunit-text warn">尚未选择知识场景 · 请点击选择</text>
    </view>
    <view class="menu">
      <view class="card menu-item" bindtap="goFlashcard">
        <text class="menu-icon">📖</text>
        <text class="menu-title">{{ui.menuFlashcardTitle}}</text>
        <text class="menu-desc">{{ui.menuFlashcardDesc}}</text>
      </view>
      <view class="card menu-item" bindtap="goExam">
        <text class="menu-icon">💬</text>
        <text class="menu-title">{{ui.menuExamTitle}}</text>
        <text class="menu-desc">{{ui.menuExamDesc}}</text>
      </view>
      <view class="card menu-item" bindtap="goVoiceExam">
        <text class="menu-icon">🎤</text>
        <text class="menu-title">{{ui.menuVoiceTitle}}</text>
        <text class="menu-desc">{{ui.menuVoiceDesc}}</text>
      </view>
      <view class="card menu-item" bindtap="goHistory">
        <text class="menu-icon">📊</text>
        <text class="menu-title">{{ui.menuHistoryTitle}}</text>
        <text class="menu-desc">{{ui.menuHistoryDesc}}</text>
      </view>
    </view>
    <view class="logout" bindtap="logout">退出登录</view>
  </block>
</view>
