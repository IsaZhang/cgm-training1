<view class="container">
  <view class="logo-area">
    <text class="title">CGM转化训练</text>
    <text class="subtitle">照护师练习与考核平台</text>
  </view>

  <block wx:if="{{!loggedIn && !showLogin}}">
    <view class="intro">
      <text class="intro-text">专为照护师打造的CGM销售转化训练平台</text>
    </view>
    <view class="menu">
      <view class="card menu-item" bindtap="goFlashcard">
        <text class="menu-icon">📖</text>
        <text class="menu-title">闪卡学习</text>
        <text class="menu-desc">CGM基础知识学习</text>
      </view>
      <view class="card menu-item" bindtap="goExam">
        <text class="menu-icon">💬</text>
        <text class="menu-title">留言考核</text>
        <text class="menu-desc">文字对话考核，AI评分</text>
      </view>
      <view class="card menu-item" bindtap="goVoiceExam">
        <text class="menu-icon">🎤</text>
        <text class="menu-title">语音考核</text>
        <text class="menu-desc">真实语音对话，更接近实战</text>
      </view>
    </view>
    <view class="login-tip" bindtap="showLoginForm">登录后可查看考核记录</view>
  </block>

  <block wx:if="{{!loggedIn && showLogin}}">
    <view class="card">
      <input class="input" placeholder="请输入姓名" bindinput="onNameInput" value="{{name}}" />
      <input class="input" placeholder="请输入手机号" type="number" bindinput="onPhoneInput" value="{{phone}}" />
      <view class="btn-primary" bindtap="login">登录</view>
      <view class="cancel-login" bindtap="cancelLogin">暂不登录</view>
    </view>
  </block>

  <block wx:if="{{loggedIn}}">
    <view class="welcome">你好，{{userInfo.name}}</view>
    <view class="menu">
      <view class="card menu-item" bindtap="goFlashcard">
        <text class="menu-icon">📖</text>
        <text class="menu-title">闪卡学习</text>
        <text class="menu-desc">CGM基础知识学习</text>
      </view>
      <view class="card menu-item" bindtap="goExam">
        <text class="menu-icon">💬</text>
        <text class="menu-title">留言考核</text>
        <text class="menu-desc">文字对话考核，AI评分</text>
      </view>
      <view class="card menu-item" bindtap="goVoiceExam">
        <text class="menu-icon">🎤</text>
        <text class="menu-title">语音考核</text>
        <text class="menu-desc">真实语音对话，更接近实战</text>
      </view>
      <view class="card menu-item" bindtap="goHistory">
        <text class="menu-icon">📊</text>
        <text class="menu-title">考核记录</text>
        <text class="menu-desc">查看历史成绩和扣分详情</text>
      </view>
    </view>
    <view class="logout" bindtap="logout">退出登录</view>
  </block>
</view>
