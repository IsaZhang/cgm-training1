.logo-area { text-align: center; padding: 60rpx 0 40rpx; }
.title { font-size: 48rpx; font-weight: bold; color: #4A90D9; display: block; }
.subtitle { font-size: 26rpx; color: #999; margin-top: 10rpx; display: block; }
.input { border: 1rpx solid #ddd; border-radius: 12rpx; padding: 24rpx; margin-bottom: 24rpx; font-size: 30rpx; }
.welcome { font-size: 34rpx; font-weight: bold; margin-bottom: 30rpx; }
.menu-item { display: flex; align-items: center; flex-wrap: wrap; }
.menu-icon { font-size: 44rpx; margin-right: 20rpx; }
.menu-title { font-size: 32rpx; font-weight: bold; flex: 1; }
.menu-desc { width: 100%; font-size: 24rpx; color: #999; margin-top: 8rpx; padding-left: 64rpx; }
.logout { text-align: center; color: #999; font-size: 26rpx; margin-top: 40rpx; }
